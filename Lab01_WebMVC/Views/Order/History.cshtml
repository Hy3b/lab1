@model List<Lab01_WebMVC.Models.Order>
@{ ViewData["Title"] = "Lịch sử mua hàng"; }

<h2 class="mb-4 fw-bold">🕒 Lịch sử đơn hàng của bạn</h2>

@if (!Model.Any()) {
    <div class="alert alert-info py-4 text-center">
        Bạn chưa có đơn hàng nào. <a asp-controller="Shop" asp-action="Index">Mua sắm ngay</a>
    </div>
} else {
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Mã Đơn</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model) {
                    <tr>
                        <td class="fw-bold text-primary">@o.Code</td>
                        <td>@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-danger fw-bold">@o.TotalAmount.ToString("N0") đ</td>
                        <td>
                            @{
                                var statusClass = o.Status switch {
                                    Lab01_WebMVC.Models.OrderStatus.Pending => "bg-warning text-dark",
                                    Lab01_WebMVC.Models.OrderStatus.Confirmed => "bg-info text-white",
                                    Lab01_WebMVC.Models.OrderStatus.Shipping => "bg-primary text-white",
                                    Lab01_WebMVC.Models.OrderStatus.Delivered => "bg-success text-white",
                                    Lab01_WebMVC.Models.OrderStatus.Cancelled => "bg-danger text-white",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @statusClass">@o.Status.ToString()</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#order-@o.Id">Xem</button>
                        </td>
                    </tr>
                    <tr class="collapse" id="order-@o.Id">
                        <td colspan="5" class="bg-light p-3">
                            <h6 class="fw-bold mb-2">Chi tiết sản phẩm:</h6>
                            <ul class="list-unstyled mb-0 ms-3">
                                @foreach (var item in o.Items) {
                                    <li class="mb-2 border-bottom pb-2">
                                        <div class="d-flex justify-content-between">
                                            <span><i class="bi bi-box"></i> @item.Product?.Name &times; <strong>@item.Qty</strong></span>
                                            <span class="text-secondary">@((item.UnitPrice * item.Qty).ToString("N0")) đ</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                            <div class="mt-3 fs-6 d-flex justify-content-between text-muted">
                                <span><i class="bi bi-geo-alt"></i> Giao đến: @o.Address</span>
                                <span><i class="bi bi-telephone"></i> @o.Phone</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
