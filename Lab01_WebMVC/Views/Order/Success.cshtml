@model string
@{ ViewData["Title"] = "Đặt hàng thành công"; }

<div class="container py-5 text-center">
    <div class="card bg-white shadow-sm border-0 py-5 px-3 mx-auto" style="max-width: 600px;">
        <div class="mb-4">
            <div class="d-inline-flex justify-content-center align-items-center rounded-circle bg-success text-white" style="width: 100px; height: 100px; font-size: 50px;">
                ✓
            </div>
        </div>
        
        <h2 class="fw-bold mb-3">Cảm ơn bạn đã đặt hàng!</h2>
        <p class="text-muted fs-5 mb-4">Đơn hàng của bạn đã được hệ thống ghi nhận và đang chờ xử lý.</p>
        
        <div class="bg-light p-3 rounded mb-4 d-inline-block">
            Mã đơn hàng: <strong class="fs-5 text-primary">@Model</strong>
        </div>
        
        <p class="text-muted small mb-4">Chúng tôi sẽ sớm liên hệ với bạn để xác nhận đơn hàng và thời gian giao.</p>
        
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary px-4 py-2">Tiếp tục mua sắm</a>
            <a asp-controller="Order" asp-action="History" class="btn btn-outline-secondary px-4 py-2">Xem lịch sử đơn</a>
        </div>
    </div>
</div>
