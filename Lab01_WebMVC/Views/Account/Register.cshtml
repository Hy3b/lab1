@model Lab01_WebMVC.Models.ViewModels.RegisterVM
@{ ViewData["Title"] = "Đăng ký"; }

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-success">ĐĂNG KÝ TÀI KHOẢN</h2>
                    <p class="text-muted">Tạo tài khoản để mua sắm dễ dàng hơn</p>
                </div>
                
                <form asp-action="Register" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 small" asp-validation-summary="ModelOnly"></div>
                    }
                    
                    <div class="form-floating mb-3">
                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                        <label asp-for="FullName">Họ và tên</label>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Email">Địa chỉ Email</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" />
                        <label asp-for="Password">Mật khẩu (ít nhất 6 ký tự)</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Confirm" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                        <label asp-for="Confirm">Xác nhận lại mật khẩu</label>
                        <span asp-validation-for="Confirm" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" required id="termsCheck">
                        <label class="form-check-label text-muted small" for="termsCheck">
                            Tôi đồng ý với <a href="#" class="text-decoration-none">Điều khoản dịch vụ</a> và <a href="#" class="text-decoration-none">Chính sách bảo mật</a>
                        </label>
                    </div>
                    
                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5 mb-3 rounded-pill shadow-sm">
                        ĐĂNG KÝ
                    </button>
                    
                    <div class="text-center text-muted small mt-4">
                        Đã có tài khoản? <a asp-action="Login" class="fw-bold text-decoration-none">Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
