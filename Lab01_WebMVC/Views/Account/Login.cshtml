@model Lab01_WebMVC.Models.ViewModels.LoginVM
@{ ViewData["Title"] = "Đăng nhập"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">ĐĂNG NHẬP</h2>
                    <p class="text-muted">Chào mừng bạn quay lại với ShopApp</p>
                </div>
                
                <form asp-action="Login" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 small" asp-validation-summary="ModelOnly"></div>
                    }
                    
                    <input type="hidden" asp-for="ReturnUrl" />
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Email">Email / Tài khoản</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" />
                        <label asp-for="Password">Mật khẩu</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label text-muted small">Ghi nhớ đăng nhập</label>
                        </div>
                        <a href="#" class="small text-decoration-none">Quên mật khẩu?</a>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold fs-5 mb-3 rounded-pill shadow-sm">
                        ĐĂNG NHẬP
                    </button>
                    
                    <div class="text-center text-muted small mt-4">
                        Bạn chưa có tài khoản? <a asp-action="Register" class="fw-bold text-decoration-none">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
