@model List<Lab01_WebMVC.Models.CartItem>
@{ ViewData["Title"] = "Giỏ hàng"; }

<h2 class="mb-4 fw-bold">🛒 Giỏ hàng của bạn</h2>

@if (!Model.Any()) {
    <div class="alert alert-info text-center py-5 shadow-sm border-0">
        <h4>Giỏ hàng đang trống!</h4>
        <p class="text-muted">Hãy tiếp tục mua sắm để nhận nhiều ưu đãi.</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary mt-3 px-4 py-2">Tiếp tục mua sắm</a>
    </div>
}
else {
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="table-responsive bg-white rounded shadow-sm">
                <table class="table table-hover align-middle text-center mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-start ps-4">Sản phẩm</th>
                            <th>Đơn giá</th>
                            <th style="width:130px">Số lượng</th>
                            <th>Thành tiền</th>
                            <th>Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model) {
                            <tr>
                                <td class="text-start ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="@(item.ImageUrl ?? "https://via.placeholder.com/60")" alt="img" class="rounded me-3 border" style="width:60px; height:60px; object-fit:cover;">
                                        <span class="fw-bold">@item.ProductName</span>
                                    </div>
                                </td>
                                <td class="text-danger fw-semibold">@item.Price.ToString("N0") đ</td>
                                <td>
                                    <form asp-action="Update" method="post" class="d-flex">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="number" name="qty" value="@item.Quantity" min="1" class="form-control form-control-sm text-center" onchange="this.form.submit()" />
                                    </form>
                                </td>
                                <td class="text-primary fw-bold">@item.Total.ToString("N0") đ</td>
                                <td>
                                    <form asp-action="Remove" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="mt-3 d-flex justify-content-between">
                <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary py-2"><i class="bi bi-arrow-left"></i> Tiếp tục mua sắm</a>
                <form asp-action="Clear" method="post">
                    <button class="btn btn-outline-danger py-2">Xóa toàn bộ giỏ hàng</button>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tổng phụ lệnh:</span>
                        <span class="fw-semibold">@Model.Sum(x => x.Total).ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Giao hàng:</span>
                        <span class="fw-semibold">Miễn phí</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">TỔNG CỘNG:</span>
                        <span class="fw-bold fs-4 text-danger">@Model.Sum(x => x.Total).ToString("N0") đ</span>
                    </div>
                    
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-success w-100 py-3 fw-bold fs-6">
                        TIẾN HÀNH THANH TOÁN <i class="bi bi-arrow-right shadow-sm"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
