<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị ShopApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold text-warning" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
      <i class="bi bi-speedometer2"></i> Admin Panel
    </a>
    <div class="navbar-collapse collapse">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">Sản phẩm</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" asp-area="Admin" asp-controller="Blog" asp-action="Index">Tin tức</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" asp-area="Admin" asp-controller="Order" asp-action="Index">Đơn hàng</a>
        </li>
      </ul>
      <ul class="navbar-nav align-items-center">
        <li class="nav-item me-3 border-end pe-3">
          <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" target="_blank">
            <i class="bi bi-box-arrow-up-right"></i> Xem Website
          </a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">
             Admin
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0 px-3 py-1">
                <button type="submit" class="btn btn-link text-danger p-0 text-decoration-none dropdown-item">Đăng xuất</button>
              </form>
            </li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="container-fluid py-4">
    @if(TempData["Ok"] != null) {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Ok"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @RenderBody()
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
