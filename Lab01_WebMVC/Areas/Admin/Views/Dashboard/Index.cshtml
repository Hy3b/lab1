@model List<Lab01_WebMVC.Models.Order>
@{ ViewData["Title"] = "Tổng quan"; }

<h2 class="mb-4 fw-bold">Thống kê nhanh</h2>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="card-title opacity-75 text-uppercase">TỔNG SẢN PHẨM</h6>
                <h2 class="mb-0 fw-bold">@ViewBag.TotalProducts</h2>
            </div>
            <div class="card-footer bg-transparent border-0 opacity-75 small">
                <a href="/Admin/Product" class="text-white text-decoration-none">Quản lý <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="card-title opacity-75 text-uppercase">TỔNG ĐƠN HÀNG</h6>
                <h2 class="mb-0 fw-bold">@ViewBag.TotalOrders</h2>
            </div>
            <div class="card-footer bg-transparent border-0 opacity-75 small">
                <a href="/Admin/Order" class="text-white text-decoration-none">Xét duyệt <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="card-title opacity-75 text-uppercase">TỔNG DOANH THU</h6>
                <h2 class="mb-0 fw-bold">@(((decimal)(ViewBag.TotalRevenue ?? 0)).ToString("N0")) đ</h2>
            </div>
            <div class="card-footer bg-transparent border-0 opacity-75 small text-dark">
                Chỉ tính giao hàng thành công
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-dark shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="card-title opacity-75 text-uppercase">BÀI VIẾT BLOG</h6>
                <h2 class="mb-0 fw-bold">@ViewBag.TotalPosts</h2>
            </div>
            <div class="card-footer bg-transparent border-0 opacity-75 small text-dark">
                <a href="/Admin/Blog" class="text-dark text-decoration-none">Viết bài <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-bold py-3 d-flex justify-content-between align-items-center">
        <span>ĐƠN HÀNG GẦN ĐÂY</span>
        <a href="/Admin/Order" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Thời gian</th>
                        <th>Số lượng sp</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Any()) {
                        <tr><td colspan="6" class="text-center py-4">Chưa có đơn hàng nào</td></tr>
                    }
                    @foreach (var o in Model) {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">@o.Code</td>
                            <td>@o.FullName <br><small class="text-muted">@o.Phone</small></td>
                            <td>@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@o.Items.Sum(x=>x.Qty)</td>
                            <td class="fw-bold text-danger">@o.TotalAmount.ToString("N0") đ</td>
                            <td>
                                <span class="badge @(o.Status == Lab01_WebMVC.Models.OrderStatus.Pending ? "bg-warning text-dark" : "bg-success")">
                                    @o.Status.ToString()
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
