@model List<Lab01_WebMVC.Models.Product>
@{ ViewData["Title"] = "Quản lý Sản phẩm"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="bi bi-box"></i> Quản lý Sản phẩm</h2>
    <a asp-action="Create" class="btn btn-primary fw-bold px-4"><i class="bi bi-plus-lg"></i> Thêm Mới</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-2 mb-4">
            <div class="col-md-4">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm kiếm theo tên..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">Tìm</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px">Ảnh</th>
                        <th>Tên SP</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th>Kho</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var p in Model) {
                        <tr>
                            <td><img src="@(p.ImageUrl ?? "https://via.placeholder.com/50")" class="rounded object-fit-cover" style="width:50px; height:50px;" /></td>
                            <td class="fw-bold">@p.Name @(p.IsFeatured ? Html.Raw("<span class='badge bg-danger ms-1'>HOT</span>") : "")</td>
                            <td><span class="badge bg-secondary">@p.Category?.Name</span></td>
                            <td class="text-danger fw-bold">@((p.SalePrice ?? p.Price).ToString("N0")) đ</td>
                            <td><span class="badge @(p.Stock > 0 ? "bg-success" : "bg-danger")">@p.Stock</span></td>
                            <td>
                                @if(p.IsDeleted) { <span class="badge bg-danger">Đã xóa</span> }
                                else if(p.IsActive) { <span class="badge bg-primary">Đang bán</span> }
                                else { <span class="badge bg-secondary">Đã ẩn</span> }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" onclick="del(@p.Id, this)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            @await Html.PartialAsync("_Pagination", new Lab01_WebMVC.Models.ViewModels.PaginationVM { Page = ViewBag.Page, TotalPages = ViewBag.TotalPages })
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
async function del(id, btn) {
    if(!confirm("Bạn có chắc muốn xóa sản phẩm này?")) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const formData = new FormData();
    formData.append("id", id);
    const res = await fetch('/Admin/Product/Delete', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token },
        body: formData
    });
    const result = await res.json();
    if(result.ok) {
        btn.closest('tr').remove();
    } else {
        alert("Lỗi khi xóa!");
    }
}
</script>
}
