@model List<Lab01_WebMVC.Models.Order>
@{ ViewData["Title"] = "Quản lý Đơn hàng"; }

<h2 class="fw-bold mb-4"><i class="bi bi-cart-check"></i> Quản lý Đơn hàng</h2>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-2 mb-4">
            <div class="col-md-3">
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="">Tất cả trạng thái</option>
                    @foreach(var stat in Enum.GetValues(typeof(Lab01_WebMVC.Models.OrderStatus)))
                    {
                        <option value="@stat" selected="@(ViewBag.Status?.ToString() == stat.ToString())">@stat.ToString()</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <a href="/Admin/Order" class="btn btn-secondary w-100">Xóa Lọc</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var o in Model) {
                        <tr>
                            <td class="fw-bold text-primary">@o.Code</td>
                            <td>
                                <strong>@o.FullName</strong><br/>
                                <small class="text-muted"><i class="bi bi-telephone"></i> @o.Phone</small>
                            </td>
                            <td>@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-danger fw-bold">@o.TotalAmount.ToString("N0") đ</td>
                            <td>
                                <select class="form-select form-select-sm border-0 bg-transparent fw-bold
                                              @(o.Status == Lab01_WebMVC.Models.OrderStatus.Pending ? "text-warning" : 
                                                o.Status == Lab01_WebMVC.Models.OrderStatus.Delivered ? "text-success" : 
                                                o.Status == Lab01_WebMVC.Models.OrderStatus.Cancelled ? "text-danger" : "text-primary")"
                                        onchange="updateStatus(@o.Id, this.value)">
                                    @foreach(var stat in Enum.GetValues(typeof(Lab01_WebMVC.Models.OrderStatus)))
                                    {
                                        <option value="@stat" class="text-dark" selected="@(o.Status.ToString() == stat.ToString())">@stat</option>
                                    }
                                </select>
                            </td>
                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@o.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i> Xem</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            @await Html.PartialAsync("_Pagination", new Lab01_WebMVC.Models.ViewModels.PaginationVM { Page = ViewBag.Page, TotalPages = ViewBag.TotalPages })
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
async function updateStatus(id, status) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const formData = new FormData();
    formData.append("id", id);
    formData.append("status", status);
    
    const res = await fetch('/Admin/Order/UpdateStatus', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token },
        body: formData
    });
    
    const result = await res.json();
    if(result.ok) {
        alert("Cập nhật trạng thái thành công!");
        location.reload();
    } else {
        alert("Có lỗi xảy ra: " + result.message);
    }
}
</script>
}
